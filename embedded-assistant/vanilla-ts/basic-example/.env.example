# Corti API Configuration
# Prerequisites:
# 1. Create a user in Corti Console (console.corti.app) for your project
# 2. Create an ROPC-enabled OAuth client with "Direct Access Grants" enabled
# 3. Fill in the credentials below

# Environment/Region ('eu' or 'us')
CORTI_ENVIRONMENT=eu

# OAuth Client ID (must have ROPC/Direct Access Grants enabled)
CORTI_CLIENT_ID=your_client_id_here

# Tenant/Realm name (e.g., 'base')
CORTI_TENANT_NAME=base

# User Credentials (created manually in Corti Console)
CORTI_USER_EMAIL=user@example.com
CORTI_USER_PASSWORD=secure_password_here
