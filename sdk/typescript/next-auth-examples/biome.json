{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "root": true,
  "css": {
    "parser": {
      "tailwindDirectives": true
    },
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 100
    },
    "linter": {
      "enabled": true
    }
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!!.next",
      "!!**/.next",
      "!!node_modules",
      "!!**/node_modules",
      "!!out",
      "!!**/out",
      "!!build",
      "!!**/build",
      "!!next-env.d.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "recommended": true
      },
      "complexity": {
        "recommended": true
      },
      "correctness": {
        "recommended": true,
        "useExhaustiveDependencies": "warn",
        "useHookAtTopLevel": "warn"
      },
      "style": {
        "recommended": true,
        "useNodejsImportProtocol": "off"
      },
      "suspicious": {
        "recommended": true,
        "noArrayIndexKey": "warn",
        "noExplicitAny": "warn",
        "noConsole": "off"
      }
    }
  }
}
