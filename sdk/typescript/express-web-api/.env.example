# Corti API credentials
# Use .env or .env.local; .env.local overrides .env

# --- Client credentials (required for /token, /token/cc, /token/bearer, and most endpoints) ---
CORTI_TENANT_NAME=your-tenant
CORTI_CLIENT_ID=your-client-id
CORTI_CLIENT_SECRET=your-client-secret

# --- ROPC (required for /token/ropc, /token/ropc-client) ---
# CORTI_ROPC_CLIENT_ID=   # optional; falls back to CORTI_CLIENT_ID
# CORTI_USERNAME=
# CORTI_PASSWORD=

# --- PKCE (required for PKCE token routes and client-variants PKCE) ---
# CORTI_PKCE_CLIENT_ID=
# CORTI_PKCE_REDIRECT_URI=
# CORTI_PKCE_TENANT_NAME=   # optional; falls back to CORTI_TENANT_NAME
# CORTI_PKCE_ENVIRONMENT=   # optional; falls back to CORTI_ENVIRONMENT

# --- Auth code (required for auth-code token routes and client-variants auth code) ---
# CORTI_AUTH_CODE_CLIENT_ID=
# CORTI_AUTH_CODE_CLIENT_SECRET=
# CORTI_AUTH_CODE_REDIRECT_URI=
# CORTI_AUTH_CODE_TENANT_NAME=   # optional; falls back to CORTI_TENANT_NAME
# CORTI_AUTH_CODE_ENVIRONMENT=   # optional; falls back to CORTI_ENVIRONMENT

# --- Global ---
# CORTI_ENVIRONMENT=eu
# PORT=3000
