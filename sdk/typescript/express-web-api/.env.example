# Corti API credentials (required for all endpoints except health)
# Use .env or .env.local; .env.local overrides .env

CORTI_TENANT_NAME=your-tenant
CORTI_CLIENT_ID=your-client-id
CORTI_CLIENT_SECRET=your-client-secret

# Optional: Corti environment (default: us)
# CORTI_ENVIRONMENT=us
# CORTI_ENVIRONMENT=eu

# Optional: Server port (default: 3000)
# PORT=3000
