{
  "name": "corti-dictation-demo",
  "version": "1.0.0",
  "description": "Real-time dictation demo using the Corti SDK",
  "main": "server.ts",
  "type": "module",
  "scripts": {
    "build:client": "esbuild client.ts --bundle --outfile=dist/client.js --format=iife --global-name=Dictation",
    "dev": "npm run build:client && tsx server.ts",
    "start": "node dist/server.js",
    "build": "npm run build:client && tsc",
    "clean": "rm -rf dist"
  },
  "keywords": ["corti", "dictation", "transcription", "speech-to-text"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@corti/sdk": "latest",
    "dotenv": "^16.4.7",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3"
  }
}