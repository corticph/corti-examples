{
  "name": "corti-ambientscribe-demo",
  "version": "1.0.0",
  "description": "Live audio transcription and clinical document generation demo using Corti SDK",
  "main": "server.ts",
  "type": "module",
  "scripts": {
    "build:client": "esbuild client.ts --bundle --outfile=dist/client.js --format=iife --global-name=AmbientScribe",
    "dev": "npm run build:client && tsx server.ts",
    "start": "node dist/server.js",
    "build": "npm run build:client && tsc",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "corti",
    "audio",
    "transcription",
    "clinical-documentation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@corti/sdk": "latest",
    "dotenv": "^17.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.37",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
