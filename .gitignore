# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
# TypeScript projects (per-project build artifacts)
typescript/node_modules
typescript/next/node_modules

# testing
/coverage

# next.js
/.next/
typescript/.next/
typescript/next/.next/
/out/

# production
/build
typescript/build
typescript/next/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
typescript/next-env.d.ts
typescript/next/next-env.d.ts

# C# / .NET
csharp/**/bin/
csharp/**/obj/

# Local Corti SDK path (copy from local.Corti.props.example to local.Corti.props)
csharp/api/local.Corti.props

